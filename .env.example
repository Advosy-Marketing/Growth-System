# =============================================================
# Advosy Growth - Environment Variables Template
# =============================================================
# These are the secrets the Supabase edge functions need.
# NOTE: If the Supabase project is TRANSFERRED to the company org
# (Settings -> General -> Transfer project), none of these need to
# be re-entered - secrets move with the project. This file is only
# needed if standing up a FRESH Supabase project from scratch.
#
# Set them with:  supabase secrets set --env-file ./.env
# Never commit the filled-in version of this file.
# =============================================================

# --- GoHighLevel (CRM) ---
# Source: GHL -> Settings -> Private Integrations (token), Calendars/Location IDs from GHL settings
GHL_TOKEN=
GHL_LOCATION_ID=
GHL_LOC=
GHL_CAL=

# --- FieldRoutes (Pestkee pest control CRM) ---
# Source: FieldRoutes -> Settings -> API keys
FR_SUBDOMAIN=
FR_AUTH_KEY=
FR_AUTH_TOKEN=

# --- ServiceTitan ---
# Source: ServiceTitan developer portal / integration settings
ST_ENV=
ST_TZ=America/Phoenix

# --- Google Maps / Places (drive-time + address autocomplete) ---
# Source: Google Cloud Console -> APIs & Credentials
MAPS_API_KEY=
MAPS_PROVIDER=google

# --- Anthropic (ai-setter SMS/email agent) ---
# Source: console.anthropic.com -> API keys
ANTHROPIC_API_KEY=

# --- Likely additional keys (TO CONFIRM - pending pull of the 10
#     newer edge functions: ai-setter, campaigns, campaign-ai,
#     nano-banana, higgsfield, meta-push, brand-assets,
#     thumbtack-webhook, daily-report, assignees, rep-availability) ---
# GEMINI_API_KEY=          (nano-banana ad creative generation)
# META_ACCESS_TOKEN=       (meta-push)
# HIGGSFIELD_API_KEY=      (higgsfield)
# THUMBTACK_* =            (thumbtack-webhook verification)

# --- Auto-provided by Supabase (do NOT set manually) ---
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# are injected into edge functions automatically by the platform.
